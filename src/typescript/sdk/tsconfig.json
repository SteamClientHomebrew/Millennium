{
	"compilerOptions": {
		"module": "ESNext",
		"target": "ES2021",
		"jsx": "react-jsx",
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"strict": true,
		"noImplicitAny": true,
		"noImplicitThis": true,
		"noImplicitReturns": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"ignoreDeprecations": "5.0",
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "build"]
}
