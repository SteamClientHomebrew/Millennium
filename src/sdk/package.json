{
  "name": "@steambrew/docs",
  "version": "1.1.2",
  "description": "Documentation for the SteamBrew SDK.",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "docs"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "publish": "lerna publish",
    "docs": "typedoc",
    "prepublish": "bun run build && bun run docs"
  },
  "devDependencies": {
    "typedoc": "^0.28.15",
    "typedoc-plugin-frontmatter": "^1.3.1",
    "typedoc-plugin-markdown": "^4.9.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    },
    "updateConfig": {
      "ignoreDependencies": [
        "react",
        "react-dom"
      ]
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "electron",
      "nx"
    ]
  },
  "workspaces": [
    "packages/*"
  ]
}
